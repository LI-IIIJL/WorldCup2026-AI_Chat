# ==================== 环境变量配置模板 ====================
# 复制此文件为 .env，填入真实的 API Key
# cp .env.example .env

# 🔴 足球数据 API Key（至少配一个才能查询实时数据）
# football-data.org（免费注册：https://www.football-data.org/client/register）
FOOTBALL_DATA_API_KEY=

# api-sports.io（Pro 订阅：https://dashboard.api-sports.io/）
API_SPORTS_KEY=

# BDL GOAT（订阅：https://bdl-dashboard.com/）
BALLDONTLIE_API_KEY=

# ==================== 服务器配置 ====================
PORT=3030

# ==================== 每设备速率限制 ====================
# 每台设备每天最多调用实时数据代理的次数
DAILY_QUOTA_PER_DEVICE=5
